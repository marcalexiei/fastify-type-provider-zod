{
  "name": "@marcalexiei/fastify-type-provider-zod",
  "version": "3.0.1",
  "description": "Zod Type Provider for Fastify@5",
  "keywords": [
    "fastify",
    "provider",
    "type",
    "zod"
  ],
  "homepage": "https://marcalexiei.github.io/fastify-type-provider-zod/",
  "bugs": {
    "url": "https://github.com/marcalexiei/fastify-type-provider-zod/issues"
  },
  "license": "MIT",
  "author": "turkerdev",
  "maintainers": [
    "marcalexiei"
  ],
  "repository": {
    "url": "https://github.com/marcalexiei/fastify-type-provider-zod"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.cts",
  "exports": {
    "require": {
      "types": "./dist/cjs/index.d.cts",
      "default": "./dist/cjs/index.cjs"
    },
    "default": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest --coverage",
    "test:runtime": "vitest --project runtime --coverage",
    "test:types": "vitest --project 'typecheck-*'",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "biome lint . && tsc --noEmit",
    "lint:fix": "biome lint --write .",
    "release": "pnpm run build && changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:lint": "tsc -p examples/tsconfig.json",
    "check-all": "pnpm run build && pnpm run test && pnpm run format:check && pnpm run lint && pnpm run docs:lint"
  },
  "dependencies": {
    "@fastify/error": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@marcalexiei/biome-config": "3.0.0",
    "@marcalexiei/oxfmt-config": "1.1.0",
    "@seriousme/openapi-schema-validator": "2.9.0",
    "@types/node": "26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "fastify": "5.8.5",
    "fastify-plugin": "6.0.0",
    "openapi-types": "12.1.3",
    "oxfmt": "0.55.0",
    "typescript": "6.0.3",
    "unplugin-isolated-decl": "0.16.0",
    "vite": "8.0.16",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@fastify/swagger": "^9.5.1",
    "fastify": "^5.5.0",
    "openapi-types": "^12.1.3",
    "zod": "^4.1.4"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "sideEffect": false
}
